---
import MetaPage from "@/components/MetaPage.astro"
import Layout from "@/layouts/Layout.astro"
import { getLang, ui, homeHref } from "@/i18n"
const lang = getLang(Astro.url)
const tr = ui[lang]
---

<Layout>
  <MetaPage slot="head" title="404" noindex />
  <prose-content>
    <h1>404</h1>
    <p>{tr.notFound}</p>
    <p><a href={homeHref(lang)}>{tr.backHome}</a></p>
  </prose-content>
</Layout>
