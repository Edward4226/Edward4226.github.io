---
import MetaPage from "@/components/MetaPage.astro"
import Layout from "@/layouts/Layout.astro"
import { getPosts, postSlug } from "@/lib/content"
import { formatDate } from "@/lib/utils"
import { ui, postHref } from "@/i18n"

const lang = "en"
const tr = ui[lang]
const posts = await getPosts(lang)

// Group by year, descending
const byYear = new Map<number, typeof posts>()
for (const post of posts) {
  const year = post.data.date.getUTCFullYear()
  if (!byYear.has(year)) byYear.set(year, [])
  byYear.get(year)!.push(post)
}
// Sort years descending
const years = [...byYear.keys()].sort((a, b) => b - a)
---

<Layout>
  <MetaPage slot="head" title={tr.archive} />
  <div class="archive">
    <h1>{tr.archive}</h1>
    {years.map((year) => (
      <section>
        <h2 class="year-label">{year}</h2>
        <ul>
          {byYear.get(year)!.map((post) => (
            <li>
              <time datetime={post.data.date.toISOString()}>
                {formatDate(post.data.date)}
              </time>
              <a href={postHref(lang, postSlug(post))}>{post.data.title}</a>
              {post.data.tags && (
                <span class="tags">
                  {post.data.tags.map((tag) => (
                    <span>#{tag}</span>
                  ))}
                </span>
              )}
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
</Layout>

<style>
  .archive {
    h1 {
      font-size: var(--step-3);
      font-weight: var(--font-weight-medium);
      margin-block-end: var(--space-l);
    }

    section {
      margin-block-end: var(--space-l);
    }

    .year-label {
      font-size: var(--step-1);
      font-weight: var(--font-weight-medium);
      color: var(--muted-foreground);
      margin-block-end: var(--space-xs);
      border-block-end: 1px solid var(--border);
      padding-block-end: var(--space-3xs);
    }

    ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-2xs);
    }

    li {
      display: flex;
      align-items: baseline;
      gap: var(--space-xs);
      flex-wrap: wrap;

      time {
        font-size: var(--step--1);
        color: var(--muted-foreground);
        flex-shrink: 0;
        font-variant-numeric: tabular-nums;
      }

      a {
        font-size: var(--step-0);

        &:hover {
          color: var(--accent);
        }
      }

      .tags {
        display: flex;
        gap: var(--space-3xs);
        font-size: var(--step--2);
        color: var(--muted-foreground);
      }
    }
  }
</style>
