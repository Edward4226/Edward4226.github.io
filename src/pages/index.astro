---
import MetaPage from "@/components/MetaPage.astro"
import Layout from "@/layouts/Layout.astro"
import { getPosts } from "@/lib/content"

const posts = (await getPosts()).slice(0, 5)
const fmtMonth = (d: Date) =>
  `${d.getFullYear()}·${String(d.getMonth() + 1).padStart(2, "0")}`
---

<Layout>
  <MetaPage slot="head" />
  <home-hero>
    <h1>枢机</h1>
    <p>在不确定的世界里,留下一些确定的判断。</p>
  </home-hero>
  <home-writing>
    <h2>「文章」</h2>
    <ul>
      {posts.map((post) => (
          <li>
            <span class="post-month">{fmtMonth(post.data.date)},</span>
            <a href={`/blog/${post.id}`}>{post.data.title}</a>
          </li>
        ))}
    </ul>
    <p class="all-posts"><a href="/blog">全部文章 →</a></p>
  </home-writing>
</Layout>

<style>
  home-writing {
    display: block;
    margin-block-start: var(--space-l);

    h2 {
      font-size: var(--step-1);
      font-weight: var(--font-weight-medium);
      margin-block-end: var(--space-xs);
    }

    ul {
      list-style: none;
      padding: 0;
      margin: 0;

      li {
        margin-block-end: var(--space-2xs);
        font-size: var(--step-0);

        .post-month {
          color: var(--muted-foreground);
          font-size: var(--step--1);
          margin-inline-end: 0.35em;
        }
      }
    }

    .all-posts {
      margin-block-start: var(--space-s);
      font-size: var(--step--1);

      a {
        color: var(--muted-foreground);

        &:hover {
          color: var(--accent);
        }
      }
    }
  }

  home-hero {
    display: block;

    @media (width >= 64rem) {
      margin-block-start: -0.2em;
    }

    h1 {
      font-size: var(--step-3);
      line-height: calc(var(--leading-offset) + 1em);
      font-weight: var(--font-weight-medium);
      letter-spacing: 0.06em;
      color: var(--foreground);
      margin-block-end: var(--space-2xs);
    }

    p {
      font-size: var(--step-0);
      color: var(--muted-foreground);
      margin: 0;
    }
  }
</style>
