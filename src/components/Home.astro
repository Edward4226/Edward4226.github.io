---
import { getPosts, postSlug } from "@/lib/content"
import { type Lang, ui, postHref, blogHref } from "@/i18n"

type Props = { lang: Lang }
const { lang } = Astro.props
const tr = ui[lang]
const posts = (await getPosts(lang)).slice(0, 5)
const fmtMonth = (d: Date) =>
  `${d.getUTCFullYear()}·${String(d.getUTCMonth() + 1).padStart(2, "0")}`
---

<home-hero>
  <h1>{tr.siteName}</h1>
  <p>{tr.tagline}</p>
</home-hero>
<home-writing>
  <h2>{tr.writing}</h2>
  <ul>
    {posts.map((post) => (
        <li>
          <span class="post-month">{fmtMonth(post.data.date)},</span>
          <a href={postHref(lang, postSlug(post))}>{post.data.title}</a>
        </li>
      ))}
  </ul>
  <p class="all-posts"><a href={blogHref(lang)}>{tr.allPosts}</a></p>
</home-writing>

<style>
  home-hero {
    display: block;

    @media (width >= 64rem) {
      margin-block-start: -0.2em;
    }

    h1 {
      font-size: var(--step-3);
      line-height: calc(var(--leading-offset) + 1em);
      font-weight: var(--font-weight-medium);
      letter-spacing: 0.04em;
      color: var(--foreground);
      margin-block-end: var(--space-2xs);
    }

    p {
      font-size: var(--step-0);
      color: var(--muted-foreground);
      margin: 0;
    }
  }

  home-writing {
    display: block;
    margin-block-start: var(--space-l);

    h2 {
      font-size: var(--step-1);
      font-weight: var(--font-weight-medium);
      margin-block-end: var(--space-xs);
    }

    ul {
      list-style: none;
      padding: 0;
      margin: 0;

      li {
        margin-block-end: var(--space-2xs);
        font-size: var(--step-0);

        .post-month {
          color: var(--muted-foreground);
          font-size: var(--step--1);
          margin-inline-end: 0.35em;
        }
      }
    }

    .all-posts {
      margin-block-start: var(--space-s);
      font-size: var(--step--1);

      a {
        color: var(--muted-foreground);

        &:hover {
          color: var(--accent);
        }
      }
    }
  }
</style>
