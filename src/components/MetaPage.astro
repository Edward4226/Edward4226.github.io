---
import { SITE } from "@/consts"
import { pageTitle } from "@/lib/content"
import { getLang, ui } from "@/i18n"

type Props = {
  title?: string
  description?: string
  noindex?: boolean
}

const lang = getLang(Astro.url)
const tr = ui[lang]
const { title, description = tr.description, noindex = false } = Astro.props

const base = Astro.site ?? new URL(Astro.url.origin)
const ogTitle = title ?? tr.siteName
const fullTitle = title ? pageTitle(title, lang) : tr.siteName
const canonical = new URL(Astro.url.pathname, base)
const ogImage = new URL(SITE.defaultPageImage, base)
---

<title>{fullTitle}</title>
<meta name="description" content={description}>
<link rel="canonical" href={canonical}>
{noindex && <meta name="robots" content="noindex, nofollow" />}

<meta property="og:title" content={ogTitle}>
<meta property="og:description" content={description}>
<meta property="og:url" content={canonical}>
<meta property="og:type" content="website">
<meta property="og:site_name" content={tr.siteName}>
<meta property="og:locale" content={tr.ogLocale}>
<meta property="og:image" content={ogImage}>
<meta property="og:image:alt" content={ogTitle}>

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={ogTitle}>
<meta name="twitter:description" content={description}>
<meta name="twitter:image" content={ogImage}>
<meta name="twitter:image:alt" content={ogTitle}>
